# Copy this file to .env and fill in your real local values.
# Never commit .env.

KEEPCON_TOKEN=
KEEPCON_ACCOUNT_NUMBER=

SCRAPEBADGER_API=
OPENAI_API=
# OPENAI_API_KEY= can also be used by the Keepcon service.

REFRESH_INTERVAL_SECONDS=900
SCRAPEBADGER_REFRESH_INTERVAL_SECONDS=86400
SCRAPEBADGER_COUNT=20
SCRAPEBADGER_TIMEZONE=America/Guayaquil

KEEPCON_OPENAI_MODEL=gpt-4.1-nano
KEEPCON_OPENAI_SYNC_CHUNK_SIZE=10
KEEPCON_INFLUENCER_THRESHOLD=5000
